---
import Layout from "../layouts/Layout.astro";
import StandingsTable from "../components/StandingsTable.jsx";
import Fixture from "../components/Fixture.jsx";
---

<Layout>
  <div class='text-center py-6'>
    <h1 class='text-lg text-green-400/80 font-medium'>
      Resultados, tabla de posiciones y fixture de la liga de Lincoln
    </h1>
    <span
      class='inline-block mt-2 px-3 py-0.5 text-[10px] font-bold uppercase tracking-widest text-green-400 border border-green-700/40 rounded-full bg-green-900/20'
    >
      Primera División — Torneo Apertura 2026
    </span>

    <p class='text-xs text-green-700 mt-1'>
      Tocá en tu club para ver toda la info
    </p>
  </div>

  <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
    <section
      class='bg-[#143814] rounded-xl border border-green-900/40 overflow-hidden shadow-2xl'
    >
      <div class='px-5 py-4 border-b border-green-900/40 bg-green-950/20'>
        <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
          Fixture
        </h2>
      </div>
      <div class='p-4'>
        <Fixture client:load />
      </div>
    </section>

    <section
      class='bg-[#143814] rounded-xl border border-green-900/40 overflow-hidden shadow-2xl'
    >
      <div class='px-5 py-4 border-b border-green-900/40 bg-green-950/20'>
        <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
          Tabla de Posiciones
        </h2>
      </div>
      <div class='p-4'>
        <StandingsTable client:load />
      </div>
    </section>
  </div>

  <div
    class='mt-8 text-center py-3 px-4 rounded-lg border border-dashed border-green-700/40 bg-green-950/20'
  >
    <p class='text-xs text-green-600 uppercase tracking-wider font-semibold'>
      Próximamente las demás divisiones
    </p>
  </div>
</Layout>
