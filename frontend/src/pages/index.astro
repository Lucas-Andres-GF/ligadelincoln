---
import Layout from '../layouts/Layout.astro'
import StandingsTable from '../components/StandingsTable.jsx'
import Fixture from '../components/Fixture.jsx'
import FixtureCategoria from '../components/FixtureCategoria'
import PartidosHoy from '../components/PartidosHoy.jsx'
---

<Layout>
  <section
    class='bg-[#143814] rounded-xl border border-green-900/40 overflow-hidden shadow-2xl mb-6'
  >
    <div
      class='px-5 py-4 border-b border-green-900/40 bg-green-950/20 flex items-center justify-between'
    >
      <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
        Próximos Partidos
      </h2>
    </div>
    <div class='p-4'>
      <PartidosHoy client:load />
    </div>
    <div class='text-center py-6'>
      <p class='text-xs text-green-700 mt-3'>
        Tocá en tu club para ver toda la info
      </p>
    </div>
  </section>

  <div class='text-center mb-4'>
    <span
      class='inline-block px-3 py-0.5 text-[16px] font-bold uppercase tracking-widest text-green-400 border border-green-700/40 rounded-full bg-green-900/20'
    >
      Primera División — Torneo Apertura 2026
    </span>
  </div>

  <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
    <section
      class='bg-[#143814] rounded-xl border border-green-900/40 shadow-2xl'
    >
      <div class='px-5 py-4 border-b border-green-900/40 bg-green-950/20'>
        <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
          Fixture
        </h2>
      </div>
      <div class='p-4'>
        <FixtureCategoria categoria={1} client:load />
      </div>
    </section>

    <section
      class='bg-[#143814] rounded-xl border border-green-900/40 overflow-hidden shadow-2xl'
    >
      <div class='px-5 py-4 border-b border-green-900/40 bg-green-950/20'>
        <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
          Tabla de Posiciones
        </h2>
      </div>
      <div class='p-4'>
        <StandingsTable categoriaId={1} client:load />
      </div>
    </section>
  </div>
</Layout>
