---
import Layout from "../layouts/Layout.astro";
import StandingsTable from "../components/StandingsTable.jsx";
import FixtureCategoria from "../components/FixtureCategoria.jsx";
---

<Layout
  title="Primera División - Liga De Lincoln | Fixture y Posiciones 2026"
  description="Fixture completo y tabla de posiciones de la Primera División de la Liga Amateur de Lincoln. Seguimiento en vivo de todos los partidos del Torneo Apertura 2026."
>
  <div class='text-center py-6'>
    <h1
      class='inline-block mt-2 px-3 py-0.5 text-[16px] font-bold uppercase tracking-widest text-green-400 border border-green-700/40 rounded-full bg-green-900/20'
    >
      Primera División — Torneo Apertura 2026
    </h1>
  </div>
  <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
    <section
      class='bg-[#143814] rounded-xl border border-green-900/40 overflow-hidden shadow-2xl'
    >
      <div class='px-5 py-4 border-b border-green-900/40 bg-green-950/20'>
        <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
          Fixture
        </h2>
      </div>
      <div class='p-4'>
        <FixtureCategoria categoria={1} client:load />
      </div>
    </section>
    <section
      class='bg-[#143814] rounded-xl border border-green-900/40 overflow-hidden shadow-2xl'
    >
      <div class='px-5 py-4 border-b border-green-900/40 bg-green-950/20'>
        <h2 class='text-sm font-bold uppercase tracking-wider text-green-400'>
          Tabla de Posiciones
        </h2>
      </div>
      <div class='p-4'>
        <StandingsTable categoriaId={1} client:load />
      </div>
    </section>
  </div>
</Layout>
