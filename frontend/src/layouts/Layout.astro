---
import '../styles/global.css'
import { ViewTransitions } from 'astro:transitions'
import Analytics from '@vercel/analytics/astro'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Liga De Lincoln - Fixture, Posiciones y Resultados del Fútbol de Lincoln',
  description = 'Seguí el fútbol de Lincoln: fixture, tabla de posiciones, resultados y equipos de la Liga Amateur de Deportes de Lincoln, Buenos Aires. Primera División actualizada.',
} = Astro.props

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || 'https://ligadelincoln.com',
)
const ogImage = new URL('/og.png', Astro.site || 'https://ligadelincoln.com')
  .href

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang='es'>
  <head>
    <meta
      name='google-site-verification'
      content='gQSoo5MIgi3Z44CX0ttWfnohnRfmhMvuzksAuhw6znc'
    />
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />

    <!-- SEO -->
    <title>{title}</title>
    <meta name='description' content={description} />
    <link rel='canonical' href={canonicalURL.href} />
    <meta name='robots' content='index, follow' />
    <meta name='author' content='Lucas Andrés Gallardo Florido' />
    <meta
      name='keywords'
      content='liga de lincoln, fútbol lincoln, liga amateur deportes lincoln, fixture lincoln, posiciones lincoln, resultados fútbol lincoln, primera división lincoln, buenos aires'
    />
    <meta name='theme-color' content='#0f2d0f' />

    <!-- Open Graph -->
    <meta property='og:type' content='website' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalURL.href} />
    <meta property='og:site_name' content='Liga De Lincoln' />
    <meta property='og:locale' content='es_AR' />
    <meta property='og:image' content={ogImage} />
    <meta property='og:image:width' content='1200' />
    <meta property='og:image:height' content='630' />

    <!-- Twitter -->
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={ogImage} />

    <!-- Favicon -->
    <link rel='icon' type='image/png' href='/favicon.png' />
    <link rel='apple-touch-icon' href='/favicon-nobg.png' />

    <!-- Fonts -->
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap'
      rel='stylesheet'
    />

    <ViewTransitions />
  </head>

  <body class='bg-[#0f2d0f] min-h-screen font-[Inter,sans-serif] text-white'>
    <!-- Header -->
    <header
      class='bg-[#143814] border-b border-green-900/50 sticky top-0 z-[60]'
    >
      <div
        class='max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4'
      >
        <!-- Logo -->
        <a
          href='/'
          class='inline-flex items-center gap-2 text-xl font-extrabold tracking-tight hover:opacity-80 transition-opacity uppercase italic shrink-0'
        >
          <img
            src='/favicon-nobg.png'
            alt=''
            width='28'
            height='28'
            class='w-7 h-7'
            loading='eager'
            decoding='async'
          />
          <span class='text-green-500'>Liga De Lincoln</span>
        </a>

        <!-- Nav Desktop -->
        <nav
          class='hidden md:flex items-center gap-1 text-green-300 font-medium uppercase text-xs'
        >
          <a
            href='/'
            class:list={[
              'px-3 py-2 rounded-md transition',
              currentPath === '/'
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}
          >
            Inicio
          </a>
          <a
            href='/clubes'
            class:list={[
              'px-3 py-2 rounded-md transition',
              currentPath === '/clubes'
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}
          >
            Clubes
          </a>
          <div class='h-4 w-px bg-green-800 mx-1'></div>
          <a
            href='/primera'
            class:list={[
              'px-2 py-2 rounded-md transition',
              currentPath.startsWith('/primera')
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}>1ra</a
          >
          <a
            href='/septima'
            class:list={[
              'px-2 py-2 rounded-md transition',
              currentPath.startsWith('/septima')
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}>7ma</a
          >
          <a
            href='/octava'
            class:list={[
              'px-2 py-2 rounded-md transition',
              currentPath.startsWith('/octava')
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}>8va</a
          >
          <a
            href='/novena'
            class:list={[
              'px-2 py-2 rounded-md transition',
              currentPath.startsWith('/novena')
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}>9na</a
          >
          <a
            href='/decima'
            class:list={[
              'px-2 py-2 rounded-md transition',
              currentPath.startsWith('/decima')
                ? 'bg-green-500/20 text-green-400'
                : 'hover:bg-green-900/30 hover:text-green-400',
            ]}>10ma</a
          >
        </nav>

        <!-- Hamburguesa -->
        <div class='md:hidden'>
          <input id='menu-toggle' type='checkbox' class='hidden peer' />
          <label
            for='menu-toggle'
            class='flex flex-col gap-1.5 cursor-pointer p-2 -mr-2'
          >
            <span class='block w-6 h-0.5 bg-green-400 rounded-full'></span>
            <span class='block w-6 h-0.5 bg-green-400 rounded-full'></span>
            <span class='block w-6 h-0.5 bg-green-400 rounded-full'></span>
          </label>

          <!-- Overlay (tocar para cerrar) -->
          <label
            for='menu-toggle'
            class='fixed inset-0 bg-black/60 backdrop-blur-sm z-[70] cursor-default hidden peer-checked:block'
          ></label>

          <!-- Menu Mobile -->
          <div
            class='absolute right-0 top-14 z-[80] bg-[#143814] rounded-xl shadow-2xl border border-green-900/40 p-2 w-56 hidden peer-checked:flex flex-col animate-in slide-in-from-top-2 fade-in duration-200'
          >
            <div
              class='flex items-center justify-between px-3 py-2 border-b border-green-900/30 mb-2'
            >
              <span class='text-green-400 font-bold text-sm uppercase'
                >Menú</span
              >
              <label
                for='menu-toggle'
                class='text-green-500 hover:text-green-300 cursor-pointer p-1'
              >
                <svg
                  class='w-5 h-5'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M6 18L18 6M6 6l12 12'></path>
                </svg>
              </label>
            </div>

            <nav class='flex flex-col gap-1'>
              <a
                href='/'
                class:list={[
                  'flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm font-medium',
                  currentPath === '/'
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <svg
                  class='w-5 h-5'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6'
                  ></path>
                </svg>
                Inicio
              </a>
              <a
                href='/clubes'
                class:list={[
                  'flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm font-medium',
                  currentPath === '/clubes'
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <svg
                  class='w-5 h-5'
                  fill='none'
                  viewBox='0 0 24 24'
                  stroke='currentColor'
                >
                  <path
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    stroke-width='2'
                    d='M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z'
                  ></path>
                </svg>
                Clubes
              </a>

              <div class='h-px bg-green-900/40 my-2'></div>

              <span
                class='px-3 py-1 text-xs text-green-600 font-semibold uppercase'
                >Categorías</span
              >

              <a
                href='/primera'
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg transition text-sm',
                  currentPath.startsWith('/primera')
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <span
                  class='w-6 h-6 rounded bg-green-900/50 flex items-center justify-center text-xs font-bold'
                  >1</span
                >
                Primera
              </a>
              <a
                href='/septima'
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg transition text-sm',
                  currentPath.startsWith('/septima')
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <span
                  class='w-6 h-6 rounded bg-green-900/50 flex items-center justify-center text-xs font-bold'
                  >7</span
                >
                Séptima
              </a>
              <a
                href='/octava'
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg transition text-sm',
                  currentPath.startsWith('/octava')
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <span
                  class='w-6 h-6 rounded bg-green-900/50 flex items-center justify-center text-xs font-bold'
                  >8</span
                >
                Octava
              </a>
              <a
                href='/novena'
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg transition text-sm',
                  currentPath.startsWith('/novena')
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <span
                  class='w-6 h-6 rounded bg-green-900/50 flex items-center justify-center text-xs font-bold'
                  >9</span
                >
                Novena
              </a>
              <a
                href='/decima'
                class:list={[
                  'flex items-center gap-3 px-3 py-2 rounded-lg transition text-sm',
                  currentPath.startsWith('/decima')
                    ? 'bg-green-500/20 text-green-400'
                    : 'text-green-200 hover:bg-green-900/30',
                ]}
              >
                <span
                  class='w-6 h-6 rounded bg-green-900/50 flex items-center justify-center text-xs font-bold'
                  >10</span
                >
                Décima
              </a>
            </nav>
          </div>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class='max-w-6xl mx-auto px-4 py-8'>
      <slot />
    </main>

    <!-- Footer -->
    <footer class='border-t border-green-900/50 mt-12'>
      <div
        class='max-w-6xl mx-auto px-4 py-6 text-center text-xs text-green-700 space-y-3'
      >
        <div class='space-y-2'>
          <p class='text-green-700/60'>Redes de Liga Lincoln</p>
          <div class='flex items-center justify-center gap-4'>
            <a
              href='https://www.instagram.com/ligadelincoln/'
              target='_blank'
              rel='noopener noreferrer'
              class='text-green-900 hover:text-green-500 transition-colors'
              aria-label='Instagram Liga Lincoln'
            >
              <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 24 24'>
                <path
                  d='M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z'
                ></path>
              </svg>
            </a>
            <a
              href='https://www.facebook.com/profile.php?id=61572030320828'
              target='_blank'
              rel='noopener noreferrer'
              class='text-green-900 hover:text-green-500 transition-colors'
              aria-label='Facebook Liga Lincoln'
            >
              <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 24 24'>
                <path
                  d='M22.675 0h-21.35C.597 0 0 .597 0 1.326v21.348C0 23.403.597 24 1.326 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.894-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24h-1.918c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116C23.403 24 24 23.403 24 22.674V1.326C24 .597 23.403 0 22.675 0z'
                ></path>
              </svg>
            </a>
          </div>
        </div>
        <p class='text-green-700/70 max-w-lg mx-auto leading-relaxed'>
          Proyecto personal para facilitar la visualización de los datos la liga
          de Lincoln. No representa una fuente oficial. Datos obtenidos de
          <a
            href='https://www.ligaamateurdedeportes.com.ar'
            target='_blank'
            rel='noopener noreferrer'
            class='text-green-500 hover:text-green-400 transition-colors underline underline-offset-2'
          >
            ligaamateurdedeportes.com.ar
          </a>
        </p>
        <p class='text-green-700/50'>
          ¿Consultas o sugerencias?
          <a
            href='mailto:gallardolucas003@gmail.com'
            class='text-green-600 hover:text-green-400 transition-colors underline underline-offset-2'
          >
            gallardolucas003@gmail.com
          </a>
        </p>
        <div class='flex items-center justify-center gap-4'>
          <a
            href='https://www.linkedin.com/in/lucas-andr%C3%A9s-gallardo-florido-4b1292234/'
            target='_blank'
            rel='noopener noreferrer'
            class='text-green-900 hover:text-green-500 transition-colors'
            aria-label='LinkedIn'
          >
            <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 24 24'>
              <path
                d='M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z'
              ></path>
            </svg>
          </a>
          <a
            href='https://www.instagram.com/lucas__gallardo/'
            target='_blank'
            rel='noopener noreferrer'
            class='text-green-900 hover:text-green-500 transition-colors'
            aria-label='Instagram'
          >
            <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 24 24'>
              <path
                d='M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z'
              ></path>
            </svg>
          </a>
          <a
            href='https://github.com/Lucas-Andres-GF'
            target='_blank'
            rel='noopener noreferrer'
            class='text-green-900 hover:text-green-500 transition-colors'
            aria-label='GitHub'
          >
            <svg class='w-4 h-4' fill='currentColor' viewBox='0 0 24 24'>
              <path
                d='M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12'
              ></path>
            </svg>
          </a>
        </div>
        <p class='text-green-900/60 text-[10px]'>
          &copy; 2026 Lucas Andrés Gallardo Florido
        </p>
      </div>
    </footer>
    <Analytics />
  </body>
</html>
